# Copy this file to .env and fill in your local PostgreSQL connection details.
# Tests connect to a dedicated test database (objectified_test by default);
# they never use your application database. All test data is rolled back after
# each test so nothing persists.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=

# Optional: test database name (default: objectified_test). Do not set this to
# your application database name.
# POSTGRES_TEST_DB=objectified_test

