# REST API Base URL (must start with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_REST_API_BASE_URL=http://localhost:8000/v1
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=[openssl rand -base64 32]

# GitHub OAuth (optional - enables Sign in with GitHub SSO; callback URL: ${NEXTAUTH_URL}/api/auth/callback/github)
# GITHUB_ID=
# GITHUB_SECRET=

# PostgreSQL (for internal auth and app data)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=objectified

# Beta Mode - Set to any value to enable beta indicator on login screen
NEXT_PUBLIC_BETA_MODE=true

